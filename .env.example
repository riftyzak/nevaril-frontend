APP_DATA_SOURCE=convex
NEXT_PUBLIC_APP_DATA_SOURCE=convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=
# Mock auth stays the safe default. Switch both auth envs to convex
# only when you want the backend-backed magic-link flow.
AUTH_SOURCE=mock
NEXT_PUBLIC_AUTH_SOURCE=mock

# M29 magic-link email delivery settings are used only when AUTH_SOURCE=convex.
# Use AUTH_EMAIL_PROVIDER=memory for local/e2e verification or AUTH_EMAIL_PROVIDER=resend
# with a real AUTH_EMAIL_FROM sender address and RESEND_API_KEY for outbound delivery.
AUTH_EMAIL_PROVIDER=memory
AUTH_EMAIL_FROM=
RESEND_API_KEY=
