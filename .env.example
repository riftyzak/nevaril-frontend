APP_DATA_SOURCE=convex
NEXT_PUBLIC_APP_DATA_SOURCE=convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=
# M30 makes Convex auth the default runtime.
# Use AUTH_SOURCE=mock and NEXT_PUBLIC_AUTH_SOURCE=mock only for explicit fallback/dev/e2e mode.
AUTH_SOURCE=convex
NEXT_PUBLIC_AUTH_SOURCE=convex

# Convex auth requires outbound email config.
# Use AUTH_EMAIL_PROVIDER=memory only for local/e2e verification.
AUTH_EMAIL_PROVIDER=resend
AUTH_EMAIL_FROM=
RESEND_API_KEY=
